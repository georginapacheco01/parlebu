{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/parlebu/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/parlebu/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/parlebu",
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
      }
    },
    "auth": {
      "type": "library",
      "root": "libs/auth",
      "entryFile": "index",
      "sourceRoot": "libs/auth/src",
      "compilerOptions": {
        "tsConfigPath": "libs/auth/tsconfig.lib.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "course-service": {
      "type": "application",
      "root": "apps/course-service",
      "entryFile": "main",
      "sourceRoot": "apps/course-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/course-service/tsconfig.app.json"
      }
    },
    "events": {
      "type": "library",
      "root": "libs/events",
      "entryFile": "index",
      "sourceRoot": "libs/events/src",
      "compilerOptions": {
        "tsConfigPath": "libs/events/tsconfig.lib.json"
      }
    },
    "learning-service": {
      "type": "application",
      "root": "apps/learning-service",
      "entryFile": "main",
      "sourceRoot": "apps/learning-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/learning-service/tsconfig.app.json"
      }
    },
    "nats": {
      "type": "library",
      "root": "libs/nats",
      "entryFile": "index",
      "sourceRoot": "libs/nats/src",
      "compilerOptions": {
        "tsConfigPath": "libs/nats/tsconfig.lib.json"
      }
    },
    "parlebu": {
      "type": "application",
      "root": "apps/parlebu",
      "entryFile": "main",
      "sourceRoot": "apps/parlebu/src",
      "compilerOptions": {
        "tsConfigPath": "apps/parlebu/tsconfig.app.json"
      }
    },
    "user-service": {
      "type": "application",
      "root": "apps/user-service",
      "entryFile": "main",
      "sourceRoot": "apps/user-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/user-service/tsconfig.app.json"
      }
    }
  }
}